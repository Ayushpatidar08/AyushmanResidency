# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT Authentication Secret Key
JWT_SECRET="JWT_SECRET_KEY"

# Admin Management
ADMIN_INITIAL_PASSWORD="defaultpasswordprovided"
ADMIN_RECOVERY_EMAIL="your-email@example.com"
ADMIN_RECOVERY_PHONE="1234567890"

# Broker Management
BROKER_DEFAULT_PASSWORD_SUFFIX="your_suffix"
DEFAULT_BROKER_NAME="Full Name(first + last)"

# Developer Contact
DEVELOPER_EMAIL="your-email@example.com"

# Stitch AI (UI/UX generation)
# API key and project ID from Stitch dashboard
STITCH_API_KEY="STITCH_API_KEY"
STITCH_PROJECT_ID="STITCH_PROJECT_ID"
